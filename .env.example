# ──────────────────────────────────────────────
# Exemplo de configuração — copie para .env
# e preencha os valores reais
# ──────────────────────────────────────────────

SECRET_KEY=troque-por-uma-chave-secreta-forte

# Em produção: False
DEBUG=True

# Em produção: lista de domínios separados por vírgula
# Ex: ALLOWED_HOSTS=meusite.com.br,www.meusite.com.br
ALLOWED_HOSTS=127.0.0.1,localhost
